# === Pandora (Private CSV Analysis Agent) ===
# Copy to .env and fill AGENT_GEMINI_API_KEY. The .env file is the ONLY manual step.

AGENT_DATABASE_URL=sqlite:///./data/agent.db

# LLM provider — auto-detected from whichever key is set below.
# Override explicitly: anthropic | gemini
# AGENT_LLM_PROVIDER=gemini

# Override model (uses provider default when blank):
# AGENT_LLM_MODEL=gemini-2.5-flash     (Gemini default — cheap & fast)

# Set the Gemini key (the analysis agent uses Gemini):
AGENT_GEMINI_API_KEY=
# AGENT_ANTHROPIC_API_KEY=    # not used by Pandora; Gemini only

# --- Sandbox & analysis limits (optional; defaults shown) ---
# AGENT_SANDBOX_TIMEOUT_SECONDS=25
# AGENT_MEMORY_LIMIT_BYTES=2147483648     # 2 GB
# AGENT_MAX_RESULT_ROWS=200
# AGENT_MAX_CATEGORY_LABELS=10
# AGENT_MAX_UPLOAD_BYTES=104857600        # ~100 MB

# --- Optional tracing (off by default; structured stdout logging is always on) ---
# LANGCHAIN_API_KEY=
# LANGCHAIN_TRACING_V2=true

PORT=8001
