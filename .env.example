# Senior Data Analyst Agent — environment configuration

# SQLite database for session metadata, datasets, messages, and audit log
AGENT_DATABASE_URL=sqlite:///./data/analyst.db

# LLM provider — auto-detected from whichever key is set below.
# Override explicitly: anthropic | gemini
# AGENT_LLM_PROVIDER=gemini

# Override model (uses provider default when blank):
# AGENT_LLM_MODEL=gemini-2.5-flash

# Set Gemini key for this project:
AGENT_GEMINI_API_KEY=

# (Anthropic key — not needed for this project but kept for skeleton compatibility)
# AGENT_ANTHROPIC_API_KEY=

# Dev server port
PORT=8001
