# CSV Data Analysis Assistant — environment variables
# Copy this file to .env and fill in the values.

# Database (SQLite — session-only, no persistence across restarts)
AGENT_DATABASE_URL=sqlite:///./data/agent.db

# LLM provider — auto-detected from whichever key is set below.
# Override explicitly: anthropic | gemini
# AGENT_LLM_PROVIDER=gemini

# LLM model — uses provider default when blank
# AGENT_LLM_MODEL=gemini-2.0-flash

# Set exactly ONE provider key:
AGENT_ANTHROPIC_API_KEY=
AGENT_GEMINI_API_KEY=your-gemini-api-key-here

# Server port
PORT=8001

# Optional: LangSmith tracing (leave blank to disable)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-key-here
# LANGCHAIN_PROJECT=csv-analysis-agent
