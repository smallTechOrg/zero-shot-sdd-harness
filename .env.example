# ─── Database ──────────────────────────────────────────────────────────────
AGENT_DATABASE_URL=sqlite:///./data/agent.db

# ─── LLM (Gemini) ──────────────────────────────────────────────────────────
# Set this key; the agent will not start without it.
AGENT_GEMINI_API_KEY=

# Model to use (default: gemini-2.5-flash)
AGENT_LLM_MODEL=gemini-2.5-flash

# ─── LangSmith observability ───────────────────────────────────────────────
# Obtain your API key from https://smith.langchain.com/
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=data-analysis-agent

# ─── Server ────────────────────────────────────────────────────────────────
PORT=8001
