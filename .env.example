# Data Analyst Agent — environment configuration
# Copy to .env and fill in your Gemini API key. .env is gitignored.

# Local SQLite database (the persistent session lives here).
AGENT_DATABASE_URL=sqlite:///./data/agent.db

# LLM provider — auto-detected from whichever key is set below.
# This agent uses Google Gemini. Default model: gemini-2.5-flash (cheap/fast).
# Override explicitly if needed: AGENT_LLM_PROVIDER=gemini
# AGENT_LLM_MODEL=gemini-2.5-flash

# Required: your Google Gemini API key.
AGENT_GEMINI_API_KEY=

# (Anthropic is supported by the skeleton but unused by this agent.)
# AGENT_ANTHROPIC_API_KEY=

PORT=8001
