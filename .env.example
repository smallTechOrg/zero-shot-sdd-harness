# DataChat — Environment Variables
# Copy this file to .env and fill in your values.
# All commands run from the repo root.

# --- Required ---
DATA_ANALYST_DATABASE_URL=sqlite:///./data_analyst.db
DATA_ANALYST_GEMINI_API_KEY=your-gemini-api-key-here

# --- Optional ---
DATA_ANALYST_LLM_MODEL=gemini-2.5-flash
DATA_ANALYST_MAX_ITERATIONS=10
DATA_ANALYST_MAX_UPLOAD_BYTES=52428800
DATA_ANALYST_LOG_LEVEL=INFO
PORT=8001
