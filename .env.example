# Data Analyst Agent — Environment Variables
# Copy this file to .env and fill in the values

# Required
ANALYST_DATABASE_URL=sqlite:///data/app.db
ANALYST_SECRET_KEY=change-me-in-production

# Optional (defaults shown)
GEMINI_API_KEY=
ANALYST_LLM_MODEL=gemini-2.5-flash
ANALYST_DATA_DIR=data
ANALYST_LOG_LEVEL=INFO
ANALYST_MAX_UPLOAD_MB=50
ANALYST_MAX_RESULT_ROWS=1000
ANALYST_QUERY_TIMEOUT_S=30
