# DataChat — environment variables
# Copy to .env and fill in values

# Database (SQLite — path relative to repo root)
DATACHAT_DATABASE_URL=sqlite:///./datachat.db

# Google Gemini API key — leave blank to run in stub mode
GEMINI_API_KEY=

# LLM model (default: gemini-2.5-flash)
DATACHAT_LLM_MODEL=gemini-2.5-flash

# Upload directory (relative to repo root)
DATACHAT_UPLOAD_DIR=uploads

# Log level
DATACHAT_LOG_LEVEL=INFO
