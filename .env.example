# Copy to .env and fill in. All vars are read by pydantic-settings with the APP_ prefix
# (see src/config.py). The recipe runs FULLY OFFLINE with no key — a key is only needed
# for a real LLM run (POST /runs against a live provider) and the real-run test gate.

# --- Runtime LLM (the product's model) -----------------------------------------------
# Default provider/model. Switching these is a CONFIG change, never a code change.
APP_LLM_PROVIDER=google_genai
APP_LLM_MODEL=gemini-2.5-flash
# Required only for a real run. Leave blank to run offline (server boots, /health is 200,
# the FakeModel-driven unit tests pass; real-run tests skip themselves when this is empty).
APP_LLM_API_KEY=

# --- Persistence ---------------------------------------------------------------------
# SQLAlchemy async URL for the metadata spine (local-first SQLite; swap to Postgres on deploy).
APP_DATABASE_URL=sqlite+aiosqlite:///./agent.db
# Directory holding the per-dataset DuckDB analytics files.
APP_DATA_DIR=./data

# --- Serving -------------------------------------------------------------------------
APP_PORT=8001

# --- Optional tuning (defaults in src/config.py) -------------------------------------
# APP_MAX_ITERATIONS=12
# APP_MAX_QUERY_ROWS=1000
# APP_QUERY_TIMEOUT_S=15.0
# APP_DURABILITY_ENABLED=false
