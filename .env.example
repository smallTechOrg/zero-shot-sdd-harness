# ── Data Analysis Agent — environment template ──────────────────────────────
# Copy to .env and fill in. .env is gitignored (never commit real keys).
# All vars use the AGENT_ prefix (Pydantic BaseSettings env_prefix="AGENT_").

# Production database (SQLite — the chosen production DB for this local app).
AGENT_DATABASE_URL=sqlite:///./data/agent.db

# ── LLM provider ────────────────────────────────────────────────────────────
# Provider is auto-detected from whichever key is set below. Leave blank for
# auto. Valid explicit values: auto | gemini | openrouter | stub
# With NO key set the app auto-engages STUB mode (yellow banner, canned answers,
# fully offline). The live provider for this project is Google Gemini.
# AGENT_LLM_PROVIDER=

# Model override (uses the provider default when blank).
# Gemini default: gemini-3.1-flash-lite (verified at the real-key gate; falls
#   back to gemini-2.5-flash on a 404 — see spec/architecture.md + README).
# AGENT_LLM_MODEL=

# ReAct loop budget (max plan/act iterations before force-finalize).
# AGENT_MAX_ITERATIONS=6

# ── Provider keys — set the one you use ─────────────────────────────────────
# Google Gemini (the live provider for this project):
AGENT_GEMINI_API_KEY=

# OpenRouter (alternate provider):
AGENT_OPENROUTER_API_KEY=

# Anthropic (skeleton baseline provider, still supported):
AGENT_ANTHROPIC_API_KEY=

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8001
