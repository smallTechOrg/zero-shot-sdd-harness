# DataChat — environment variables
# Copy this file to .env and fill in the values:  cp .env.example .env
# All app settings use the DATA_ANALYST_ prefix (pydantic-settings).

# --- LLM provider (Google Gemini) ---
# Real-first: there is no stub/offline mode. The key is REQUIRED to run and to test.
# Get one at https://aistudio.google.com/apikey
# langchain-google-genai reads GOOGLE_API_KEY; the app exports it from the value below.
DATA_ANALYST_GEMINI_API_KEY=
DATA_ANALYST_LLM_PROVIDER=google_genai
DATA_ANALYST_LLM_MODEL=gemini-2.5-flash

# --- Database (SQLite — async via aiosqlite) ---
DATA_ANALYST_DATABASE_URL=sqlite+aiosqlite:///./datachat.db
# Test DB (file-backed, auto-created/dropped by conftest.py)
TEST_DATABASE_URL=sqlite+aiosqlite:///./datachat_test.db

# --- Agent loop ---
DATA_ANALYST_MAX_ITERATIONS=6
DATA_ANALYST_MAX_UPLOAD_BYTES=52428800
DATA_ANALYST_SAMPLE_ROWS=20

# --- Server / logging ---
PORT=8001
DATA_ANALYST_LOG_LEVEL=INFO

# --- Web UI ---
# The built UI (frontend/out) is served by this server at / on the same port — no CORS needed.
# Override the location of the built UI if needed:
# DATA_ANALYST_UI_DIR=frontend/out
# CORS only matters if you run the Next.js dev server separately (npm run dev on :3000):
# DATA_ANALYST_CORS_ORIGINS=http://localhost:3000
# Then set the API base for that dev server in frontend/.env.local:
# NEXT_PUBLIC_API_BASE=http://localhost:8001
