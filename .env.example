AGENT_DATABASE_URL=sqlite:///./data/agent.db

# LLM provider — auto-detected from whichever key is set below.
# Override explicitly: anthropic | gemini
# AGENT_LLM_PROVIDER=anthropic

# Override model (uses provider default when blank):
# AGENT_LLM_MODEL=claude-sonnet-4-6   (Anthropic default)
# AGENT_LLM_MODEL=gemini-2.5-pro        (Gemini default)

# Set exactly ONE provider key:
AGENT_ANTHROPIC_API_KEY=
AGENT_GEMINI_API_KEY=

# Model routing (optional) — map a logical task to a model id. Blank → the
# provider default. The agent prices each call at the model the API reports,
# so a routed call is costed at its real tier.
#   Anthropic example:
# AGENT_MODEL_CLASSIFY=claude-haiku-4-5
# AGENT_MODEL_TOOLS=claude-sonnet-4-6
# AGENT_MODEL_REASON=claude-opus-4-8
#   Gemini example:
# AGENT_MODEL_CLASSIFY=gemini-2.5-flash
# AGENT_MODEL_TOOLS=gemini-2.5-flash
# AGENT_MODEL_REASON=gemini-2.5-pro

PORT=8001
